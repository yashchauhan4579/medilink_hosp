# Fight detection — OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Fight detection — Gemini (fallback, comma-separated)
GEMINI_API_KEYS=key1,key2,key3

# Fight detection camera IDs (comma-separated, leave empty to disable)
FIGHT_CAMERA_IDS=
FIGHT_COOLDOWN_SECONDS=120

# Sound detection
SOUND_DETECTION_ENABLED=false
SOUND_SOURCE=rtsp
SOUND_DB_THRESHOLD=10
SOUND_COOLDOWN_SECONDS=30
SOUND_CALIBRATION_DURATION=120

# WhatsApp alerts (configured via /api/settings)
# WHATSAPP_INSTANCE_ID=
# WHATSAPP_API_TOKEN=
# WHATSAPP_RECIPIENT_PHONE=
